{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://valore-api-279d7c3cc379.herokuapp.com/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
